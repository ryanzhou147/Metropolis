# ============================================
# Metropolis (Argus) — Environment Variables
# Copy this file: cp .env.example .env
# ============================================

# --- PostgreSQL (required) ---
POSTGRES_USER=metropolis
POSTGRES_PASSWORD=changeme
POSTGRES_DB=metropolis
DATABASE_URL=postgresql://metropolis:changeme@postgres:5432/metropolis

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Gemini AI (required for agent + analysis) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (optional — used for pgvector embeddings; falls back to keyword search) ---
# OPENAI_API_KEY=your-openai-api-key-here

# --- ACLED (optional — needed for ACLED data ingestion) ---
# ACLED_API_KEY=your-acled-api-key-here

# --- ElevenLabs (optional — voice input transcription) ---
# ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# --- Backend CORS (optional — defaults to localhost:5173) ---
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend (optional) ---
# VITE_API_URL=/api
# VITE_ELEVENLABS_API_KEY=your-elevenlabs-key
