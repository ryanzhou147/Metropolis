# --- PostgreSQL (required) ---
DATABASE_URL=postgresql://metropolis:changeme@localhost:5432/metropolis

# --- Gemini AI (required for agent + analysis) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (optional — pgvector embeddings; falls back to keyword search) ---
# OPENAI_API_KEY=your-openai-api-key-here

# --- ACLED (optional — needed for ACLED data ingestion) ---
# ACLED_API_KEY=your-acled-api-key-here

# --- ElevenLabs (optional — voice input transcription) ---
# ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# --- Redis (optional — caching; app works without it) ---
# REDIS_URL=redis://localhost:6379/0

# --- CORS (optional — defaults to localhost:5173) ---
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
